{
  "name": "@pokechamps/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PokeChamps HTTP/WS backend. Fastify + sqlite + JWT auth. Hosts the authoritative match state; tui/web clients connect via REST + WebSocket.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@pokechamps/core": "*",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
