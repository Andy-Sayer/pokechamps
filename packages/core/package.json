{
  "name": "@pokechamps/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pure domain logic for PokeChamps: types, parser, predictions, inference, speed, hazards, gimmicks. No Node-only imports leak into consumers.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "refresh-data": "tsx src/scripts/refresh-data.ts",
    "refresh-pikalytics": "tsx src/scripts/refresh-pikalytics.ts",
    "demo-team": "tsx src/scripts/generate-demo-team.ts",
    "validate-format": "tsx src/scripts/validate-format.ts",
    "bring-matrix": "tsx src/scripts/bring-matrix.ts",
    "bring-lookup": "tsx src/scripts/bring-lookup.ts",
    "build-dossier": "tsx src/scripts/build-dossier.ts",
    "preview-gauntlet": "tsx src/scripts/preview-gauntlet.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@pkmn/data": "^0.10.10",
    "@pkmn/dex": "^0.10.11",
    "@smogon/calc": "^0.11.0"
  },
  "optionalDependencies": {
    "@pkmn/sim": "^0.10.11"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
